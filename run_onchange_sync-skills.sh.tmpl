#!/bin/bash
# Sync personal skills into ~/.claude/skills/
# skills hash: {{ output "ls" "-R" (joinPath .chezmoi.sourceDir "skills") | sha256sum }}
set -e

SKILLS_DIR="$HOME/.claude/skills"
PERSONAL_SRC="{{ .chezmoi.sourceDir }}/skills"

# Remove existing symlink or directory, start fresh
if [ -L "$SKILLS_DIR" ]; then
    rm "$SKILLS_DIR"
fi
mkdir -p "$SKILLS_DIR"

# Copy personal skills
for skill_dir in "$PERSONAL_SRC"/*/; do
    [ -d "$skill_dir" ] || continue
    skill_name="$(basename "$skill_dir")"
    # Remove existing and replace (handles updates)
    rm -rf "$SKILLS_DIR/$skill_name"
    cp -R "$skill_dir" "$SKILLS_DIR/$skill_name"
done

echo "Personal skills synced to $SKILLS_DIR"
ls "$SKILLS_DIR" | wc -l | xargs echo "Total skills:"
