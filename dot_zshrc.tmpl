# oh-my-zsh
export ZSH="$HOME/.oh-my-zsh"
ZSH_THEME="robbyrussell"
plugins=(git direnv zsh-syntax-highlighting zsh-autosuggestions)
source $ZSH/oh-my-zsh.sh

# 1Password CLI plugins
{{ if eq .chezmoi.os "darwin" -}}
source {{ .chezmoi.homeDir }}/.config/op/plugins.sh
{{- end }}

# Language runtimes & tools
export DENO_INSTALL="{{ .chezmoi.homeDir }}/.deno"
export PATH="$DENO_INSTALL/bin:$PATH"

{{ if eq .chezmoi.os "darwin" -}}
export PATH="/opt/homebrew/opt/openjdk/bin:$PATH"
{{- end }}

export PATH="{{ .chezmoi.homeDir }}/go/bin:$PATH"

# rye (Python)
. "$HOME/.rye/env"

# nvm
export NVM_DIR="$HOME/.nvm"
{{ if eq .chezmoi.os "darwin" -}}
[ -s "/opt/homebrew/opt/nvm/nvm.sh" ] && \. "/opt/homebrew/opt/nvm/nvm.sh"
[ -s "/opt/homebrew/opt/nvm/etc/bash_completion.d/nvm" ] && \. "/opt/homebrew/opt/nvm/etc/bash_completion.d/nvm"
{{ else -}}
[ -s "$NVM_DIR/nvm.sh" ] && \. "$NVM_DIR/nvm.sh"
[ -s "$NVM_DIR/bash_completion" ] && \. "$NVM_DIR/bash_completion"
{{- end }}

# Tool-specific bins
export OMNARA_INSTALL="$HOME/.omnara"
export PATH="$OMNARA_INSTALL/bin:$PATH"
export PATH="{{ .chezmoi.homeDir }}/.exo/bin:$PATH"
export PATH="{{ .chezmoi.homeDir }}/.opencode/bin:$PATH"

# Aliases
alias claude-render="{{ .chezmoi.homeDir }}/Dropbox/obsidian/Alex3/.claude/scripts/render.py"
